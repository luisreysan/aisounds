# =============================================================================
# AI Sounds — environment variables template
# =============================================================================
# Copy this file to `apps/web/.env.local` and fill in the values. Never commit
# real secrets. The web app reads these at runtime.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVICE ROLE key — server-only, bypasses RLS, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: direct Postgres connection string, used to run migrations via psql.
#   postgres://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=

# -----------------------------------------------------------------------------
# NextAuth.js (GitHub OAuth only)
# -----------------------------------------------------------------------------
# Must match your deployed URL in production (e.g. https://aisounds.dev).
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# -----------------------------------------------------------------------------
# GitHub OAuth App
# -----------------------------------------------------------------------------
# https://github.com/settings/developers → New OAuth App
# Homepage URL:            http://localhost:3000
# Authorization callback:  http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Umami Analytics (self-hosted on Railway)
# -----------------------------------------------------------------------------
# Only the two public vars are required by the client script tag.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_URL=
