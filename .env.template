# =============================================================================
# AI Sounds — environment variables template
# =============================================================================
# Copy this file to `apps/web/.env.local` and fill in the values. Never commit
# real secrets. The web app reads these at runtime.
#
# GitHub OAuth is NOT configured through app env vars — Supabase handles the
# OAuth flow end-to-end. The GitHub Client ID and Secret go into:
#   Supabase Dashboard -> Authentication -> OAuth Apps -> GitHub
# See `docs/auth-setup.md` for the full walkthrough.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (public + server)
# -----------------------------------------------------------------------------
# Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVICE ROLE key — server-only, bypasses RLS, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: direct Postgres connection string, used to run migrations via psql.
#   postgres://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=

# -----------------------------------------------------------------------------
# Public site URL (used by the OAuth redirect_to)
# -----------------------------------------------------------------------------
# In local dev: http://localhost:3000
# In production: your canonical public URL (e.g. https://aisounds.vercel.app)
# On Vercel you can leave this empty — the app reads the VERCEL_URL fallback.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Umami Analytics (self-hosted on Railway, optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_URL=
