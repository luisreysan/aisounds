# Claude Code session-summary-tts — config template.
# Real config lives at ~/.claude/hooks/session-summary-tts.env (chmod 600).
# Run install.mjs to generate it interactively, or copy this file there manually.

# ── Required ─────────────────────────────────────────────────────────────────

# elevenlabs | gemini
TTS_PROVIDER=elevenlabs

# ElevenLabs (required if TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=
# Default voice: Daniel (onwK4e9ZLuTAKqWW03F9). Override with any voice ID
# from https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Gemini (required if TTS_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore

# ── Optional ─────────────────────────────────────────────────────────────────

# Master switch. Set to 0/false/no/off to disable without uninstalling.
ENABLED=1

# Skip the readout when the session has fewer than this many assistant chars.
# Stops "hi"-style sessions from generating awkward summaries.
MIN_ASSISTANT_CHARS=200

# Comma-separated path substrings. Sessions whose cwd contains any will skip.
# Useful for sensitive repos.
# CWD_BLOCKLIST=secrets-repo,internal-prod

# Override the summary system prompt entirely.
# SUMMARY_PROMPT=

# Model used for the summary call. Cheaper = faster.
SESSION_SUMMARY_MODEL=claude-haiku-4-5

# Custom claude CLI path (otherwise uses `claude` from PATH).
# CLAUDE_CLI=/opt/homebrew/bin/claude

# Print the summary to stdout instead of synthesizing it. Handy for debugging.
# DRY_RUN=1

# Print debug logs to stderr.
# SESSION_SUMMARY_TTS_DEBUG=1
